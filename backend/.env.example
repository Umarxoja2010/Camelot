APP_NAME="Camelot LMS"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Asia/Tashkent
APP_URL=http://localhost:8000

APP_LOCALE=uz
APP_FALLBACK_LOCALE=ru
APP_FAKER_LOCALE=en_US

# Qo'llab-quvvatlanadigan tillar
APP_SUPPORTED_LOCALES=uz,ru,en

# Frontend manzili (CORS uchun)
FRONTEND_URL=http://localhost:5173

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=debug

# Eng oddiy boshlash uchun SQLite. MySQL kerak bo'lsa quyidagini o'zgartiring.
DB_CONNECTION=sqlite
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=camelot_lms
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120

FILESYSTEM_DISK=public
QUEUE_CONNECTION=database
CACHE_STORE=database

MAIL_MAILER=log
MAIL_FROM_ADDRESS="info@camelot.uz"
MAIL_FROM_NAME="${APP_NAME}"

# ===== Bildirishnoma drayverlari =====
# Qaysi kanal orqali yuborilsin: log | telegram | sms
NOTIFICATION_CHANNEL=log

# Telegram bot (BotFather'dan token oling)
TELEGRAM_BOT_TOKEN=
TELEGRAM_ENABLED=false

# SMS (Eskiz.uz)
SMS_ENABLED=false
ESKIZ_EMAIL=
ESKIZ_PASSWORD=
ESKIZ_FROM=4546
ESKIZ_BASE_URL=https://notify.eskiz.uz/api
